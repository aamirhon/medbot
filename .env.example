# ─── Telegram ─────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_TELEGRAM_IDS=123456789

# ─── База и Redis ─────────────────────────────────────
# Для запуска через docker compose используйте имена сервисов:
DATABASE_URL=postgresql+asyncpg://medbot:medbot@postgres:5432/medbot
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=medbot

# Для локального запуска (без docker) используйте localhost:
# DATABASE_URL=postgresql+asyncpg://medbot:medbot@localhost:5432/medbot
# REDIS_URL=redis://localhost:6379/0

# ─── 1С ───────────────────────────────────────────────
# Для разработки с мок-сервером:
ONE_C_URL=http://mock_1c:8001
ONE_C_USER=mock
ONE_C_PASSWORD=mock

# Для production:
# ONE_C_URL=http://your-1c-server.uz/YourBase
# ONE_C_USER=integration_bot
# ONE_C_PASSWORD=secret_password

ONE_C_TIMEOUT=30

# ─── Интервалы синхронизации (секунды) ────────────────
# Для разработки можно уменьшить до 30, чтобы быстрее видеть результат
SYNC_PRODUCTS_INTERVAL=900
SYNC_STOCK_INTERVAL=300
SYNC_ORDERS_INTERVAL=600
SYNC_PAYMENTS_INTERVAL=600
