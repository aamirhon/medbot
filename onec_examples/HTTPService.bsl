// ════════════════════════════════════════════════════════════════════════
// HTTP-сервис в 1С:Предприятие
// Создаётся в Конфигураторе: Общие → HTTP-сервисы → Добавить
// 
// Имя:        BotIntegration
// Корневой URL: bot
// 
// Шаблоны URL:
//   /clients/check?inn={inn}                    GET   ПолучитьКлиентаПоИНН
//   /catalog/products                           GET   ПолучитьТовары
//   /catalog/stock                              GET   ПолучитьОстатки
//   /orders/create-with-invoice                 POST  СоздатьЗаказСоСчётом
//   /orders/{id}/payment-status                 GET   ПолучитьСтатусОплаты
//   /orders/statuses                            POST  ПолучитьСтатусыЗаказов
// ════════════════════════════════════════════════════════════════════════


// ─── 1. Проверка клиента по ИНН ───────────────────────────────────────

Функция ПолучитьКлиентаПоИНН(Запрос)
    
    ИНН = Запрос.ПараметрыURL.Получить("inn");
    Если ИНН = Неопределено Тогда
        Возврат СоздатьОтветJSON(400, Новый Структура("error", "INN required"));
    КонецЕсли;
    
    // Ищем контрагента по ИНН
    Запрос_ = Новый Запрос;
    Запрос_.Текст = 
        "ВЫБРАТЬ
        |    Контрагент.Ссылка,
        |    Контрагент.Наименование,
        |    Контрагент.ИНН,
        |    Контрагент.КонтактныйТелефон,
        |    Контрагент.ЮридическийАдрес,
        |    Контрагент.УровеньКлиента,
        |    Контрагент.ТипКлиента
        |ИЗ
        |    Справочник.Контрагенты КАК Контрагент
        |ГДЕ
        |    Контрагент.ИНН = &ИНН
        |    И НЕ Контрагент.ПометкаУдаления";
    Запрос_.УстановитьПараметр("ИНН", ИНН);
    
    Выборка = Запрос_.Выполнить().Выбрать();
    
    Если НЕ Выборка.Следующий() Тогда
        Возврат СоздатьОтветJSON(200, Новый Структура("found", Ложь));
    КонецЕсли;
    
    // Маппинг уровня клиента
    УровеньСтрока = "standard";
    Если Выборка.УровеньКлиента = Перечисления.УровниКлиентов.VIP Тогда
        УровеньСтрока = "vip";
    ИначеЕсли Выборка.УровеньКлиента = Перечисления.УровниКлиентов.Ограниченный Тогда
        УровеньСтрока = "limited";
    КонецЕсли;
    
    ТипСтрока = "clinic";
    Если Выборка.ТипКлиента = Перечисления.ТипыКлиентов.Госучреждение Тогда
        ТипСтрока = "government";
    КонецЕсли;
    
    Результат = Новый Структура;
    Результат.Вставить("found",     Истина);
    Результат.Вставить("one_c_id",  СтрокаУникальногоИдентификатора(Выборка.Ссылка.УникальныйИдентификатор()));
    Результат.Вставить("name",      Выборка.Наименование);
    Результат.Вставить("inn",       Выборка.ИНН);
    Результат.Вставить("tier",      УровеньСтрока);
    Результат.Вставить("type",      ТипСтрока);
    Результат.Вставить("phone",     Выборка.КонтактныйТелефон);
    Результат.Вставить("address",   Выборка.ЮридическийАдрес);
    
    Возврат СоздатьОтветJSON(200, Результат);
    
КонецФункции


// ─── 2. Получение товаров ─────────────────────────────────────────────

Функция ПолучитьТовары(Запрос)
    
    Запрос_ = Новый Запрос;
    Запрос_.Текст = 
        "ВЫБРАТЬ
        |    Номенклатура.Ссылка,
        |    Номенклатура.Артикул КАК sku,
        |    Номенклатура.Наименование КАК name,
        |    Номенклатура.ЕдиницаХраненияОстатков.Наименование КАК unit,
        |    Номенклатура.Родитель.Ссылка КАК category,
        |    Номенклатура.Родитель.Наименование КАК category_name,
        |    Цены.Цена КАК price,
        |    НЕ Номенклатура.ПометкаУдаления КАК is_active
        |ИЗ
        |    Справочник.Номенклатура КАК Номенклатура
        |        ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, ВидЦены = &ВидЦены) КАК Цены
        |        ПО Номенклатура.Ссылка = Цены.Номенклатура
        |ГДЕ
        |    НЕ Номенклатура.ЭтоГруппа
        |    И НЕ Номенклатура.ПометкаУдаления";
    Запрос_.УстановитьПараметр("ВидЦены", Справочники.ВидыЦен.НайтиПоНаименованию("Основная"));
    
    Массив = Новый Массив;
    Выборка = Запрос_.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Товар = Новый Структура;
        Товар.Вставить("one_c_id",          СтрокаУникальногоИдентификатора(Выборка.Ссылка.УникальныйИдентификатор()));
        Товар.Вставить("sku",               Выборка.sku);
        Товар.Вставить("name",              Выборка.name);
        Товар.Вставить("unit",              Выборка.unit);
        Товар.Вставить("price",             Выборка.price);
        Товар.Вставить("category_one_c_id", СтрокаУникальногоИдентификатора(Выборка.category.УникальныйИдентификатор()));
        Товар.Вставить("category_name",     Выборка.category_name);
        Товар.Вставить("is_active",         Выборка.is_active);
        Массив.Добавить(Товар);
    КонецЦикла;
    
    Возврат СоздатьОтветJSON(200, Массив);
    
КонецФункции


// ─── 3. Создание заказа со счётом и договором ─────────────────────────

Функция СоздатьЗаказСоСчётом(Запрос)
    
    ТелоJSON = Запрос.ПолучитьТелоКакСтроку("UTF-8");
    Чтение = Новый ЧтениеJSON;
    Чтение.УстановитьСтроку(ТелоJSON);
    Данные = ПрочитатьJSON(Чтение, Истина);
    
    // Находим контрагента
    КонтрагентСсылка = Справочники.Контрагенты.ПолучитьСсылку(
        Новый УникальныйИдентификатор(Данные["client_one_c_id"])
    );
    
    Если КонтрагентСсылка.Пустая() Тогда
        Возврат СоздатьОтветJSON(404, Новый Структура("error", "Client not found"));
    КонецЕсли;
    
    // Создаём заказ покупателя
    Заказ = Документы.ЗаказПокупателя.СоздатьДокумент();
    Заказ.Дата       = ТекущаяДата();
    Заказ.Контрагент = КонтрагентСсылка;
    Заказ.Комментарий = СокрЛП(Данные["comment"]);
    Заказ.ВнешнийИдентификатор = Данные["external_ref"];   // наш UUID
    
    // Заполняем товары
    Для Каждого ТоварJSON Из Данные["items"] Цикл
        НомСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", ТоварJSON["sku"]);
        Если НомСсылка.Пустая() Тогда
            Продолжить;
        КонецЕсли;
        
        Строка = Заказ.Товары.Добавить();
        Строка.Номенклатура = НомСсылка;
        Строка.Количество   = ТоварJSON["qty"];
        Строка.Цена         = ТоварJSON["unit_price"];
        Строка.Сумма        = ТоварJSON["subtotal"];
    КонецЦикла;
    
    Заказ.Записать(РежимЗаписиДокумента.Проведение);
    
    // Генерируем счёт на оплату на основании заказа
    СчётНаОплату = Документы.СчётНаОплату.СоздатьДокумент();
    СчётНаОплату.Дата          = ТекущаяДата();
    СчётНаОплату.Контрагент    = КонтрагентСсылка;
    СчётНаОплату.ДокументОснование = Заказ.Ссылка;
    СчётНаОплату.ЗаполнитьПоОснованию(Заказ.Ссылка);
    СчётНаОплату.Записать();
    
    // Печатаем счёт и договор в PDF, сохраняем в публичной папке
    URLСчёта    = СохранитьПечатнуюФорму(СчётНаОплату, "СчётНаОплату");
    URLДоговора = СохранитьПечатнуюФорму(СчётНаОплату, "Договор");
    
    Результат = Новый Структура;
    Результат.Вставить("one_c_id",       СтрокаУникальногоИдентификатора(Заказ.Ссылка.УникальныйИдентификатор()));
    Результат.Вставить("invoice_number", СчётНаОплату.Номер);
    Результат.Вставить("invoice_url",    URLСчёта);
    Результат.Вставить("contract_url",   URLДоговора);
    Результат.Вставить("total_amount",   Заказ.СуммаДокумента);
    
    Возврат СоздатьОтветJSON(200, Результат);
    
КонецФункции


// ─── 4. Проверка статуса оплаты ───────────────────────────────────────

Функция ПолучитьСтатусОплаты(Запрос)
    
    OneCId = Запрос.ПараметрыURL.Получить("id");
    ЗаказСсылка = Документы.ЗаказПокупателя.ПолучитьСсылку(
        Новый УникальныйИдентификатор(OneCId)
    );
    
    // Ищем оплату по этому заказу
    Запрос_ = Новый Запрос;
    Запрос_.Текст = 
        "ВЫБРАТЬ
        |    СУММА(Расчёты.Сумма) КАК ОплаченнаяСумма,
        |    МАКСИМУМ(Расчёты.Период) КАК ПоследняяОплата
        |ИЗ
        |    РегистрНакопления.РасчётыСКонтрагентами КАК Расчёты
        |ГДЕ
        |    Расчёты.Сделка = &Заказ
        |    И Расчёты.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)";
    Запрос_.УстановитьПараметр("Заказ", ЗаказСсылка);
    
    Выборка = Запрос_.Выполнить().Выбрать();
    Выборка.Следующий();
    
    Оплачен = Выборка.ОплаченнаяСумма >= ЗаказСсылка.СуммаДокумента;
    
    Результат = Новый Структура;
    Результат.Вставить("paid",    Оплачен);
    Результат.Вставить("amount",  Выборка.ОплаченнаяСумма);
    Результат.Вставить("paid_at", ?(Оплачен, Формат(Выборка.ПоследняяОплата, "ДФ=yyyy-MM-ddTHH:mm:ss"), Неопределено));
    
    Возврат СоздатьОтветJSON(200, Результат);
    
КонецФункции


// ─── Вспомогательные функции ──────────────────────────────────────────

Функция СоздатьОтветJSON(КодСтатуса, Данные)
    Запись = Новый ЗаписьJSON;
    Запись.УстановитьСтроку();
    ЗаписатьJSON(Запись, Данные);
    
    Ответ = Новый HTTPСервисОтвет(КодСтатуса);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(Запись.Закрыть(), КодировкаТекста.UTF8);
    Возврат Ответ;
КонецФункции

Функция СохранитьПечатнуюФорму(Документ, ИмяМакета)
    // Печатаем документ в PDF и сохраняем в публичную папку.
    // URL зависит от настроек публикации файлов.
    
    ТабДокумент = Новый ТабличныйДокумент;
    МассивОбъектов = Новый Массив;
    МассивОбъектов.Добавить(Документ.Ссылка);
    
    УправлениеПечатью.ПечатьПоМакету(ТабДокумент, ИмяМакета, МассивОбъектов);
    
    ИмяФайла = ИмяМакета + "_" + Документ.Номер + ".pdf";
    ПолныйПуть = "C:\inetpub\wwwroot\bot_files\" + ИмяФайла;
    
    ТабДокумент.Записать(ПолныйПуть, ТипФайлаТабличногоДокумента.PDF);
    
    Возврат "https://files.example.uz/bot_files/" + ИмяФайла;
КонецФункции
